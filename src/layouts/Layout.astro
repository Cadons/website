---
import config from '../data/config.json';

interface Props {
  title: string;
  description?: string;
  /** keywords array (e.g. post tags) rendered as <meta name="keywords"> */
  keywords?: string[];
  /** Open Graph image URL (absolute). Falls back to /og-default.png */
  image?: string;
  /** 'article' for blog posts, 'website' for everything else */
  type?: 'website' | 'article';
  /** ISO date string for article published_time */
  publishedDate?: Date;
}

const {
  title,
  description = config.job,
  keywords = [],
  image,
  type = 'website',
  publishedDate,
} = Astro.props;

const siteUrl = `https://${config.domain}`;
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image ?? `${siteUrl}/og-default.png`;

const { light, dark } = config.theme;
//create css variables taking the light and dark theme colors from the config file
const themeVars = [
  `--color-text-subtle-light:${light.textSubtle}`,
  `--color-text-muted-light:${light.textMuted}`,
  `--color-line-light:${light.line}`,
  `--color-card-bg-light:${light.cardBg}`,
  `--color-nav-bg-light:${light.navBg}`,
  `--color-nav-border-light:${light.navBorder}`,
  `--color-hover-surface-light:${light.hoverSurface}`,
  `--color-text-subtle-dark:${dark.textSubtle}`,
  `--color-text-muted-dark:${dark.textMuted}`,
  `--color-line-dark:${dark.line}`,
  `--color-card-bg-dark:${dark.cardBg}`,
  `--color-nav-bg-dark:${dark.navBg}`,
  `--color-nav-border-dark:${dark.navBorder}`,
  `--color-hover-surface-dark:${dark.hoverSurface}`,
].join(';');
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth" style={themeVars}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary meta -->
  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
  <meta name="author" content={config.author} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content={config.author} />
  <meta property="og:locale" content="en_US" />
  {type === 'article' && publishedDate && (
    <meta property="article:published_time" content={publishedDate.toISOString()} />
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <script is:inline define:vars={{ canonicalHost: config.domain, ghPagesHost: config.gh_pages_domain }}>
    if (window.location.hostname === ghPagesHost && canonicalHost) {
      const canonicalUrl = `${window.location.protocol}//${canonicalHost}${window.location.pathname}${window.location.search}${window.location.hash}`;
      window.location.replace(canonicalUrl);
    }
  </script>

  <!-- Dark mode: set class before paint to avoid flash -->
  <script is:inline>
    const theme = localStorage.getItem('theme');
    if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  </script>

  <style is:global>
    :root {
      --color-text-subtle: var(--color-text-subtle-light);
      --color-text-muted: var(--color-text-muted-light);
      --color-line: var(--color-line-light);
      --color-card-bg: var(--color-card-bg-light);
      --color-nav-bg: var(--color-nav-bg-light);
      --color-nav-border: var(--color-nav-border-light);
      --color-hover-surface: var(--color-hover-surface-light);
    }

    .dark {
      --color-text-subtle: var(--color-text-subtle-dark);
      --color-text-muted: var(--color-text-muted-dark);
      --color-line: var(--color-line-dark);
      --color-card-bg: var(--color-card-bg-dark);
      --color-nav-bg: var(--color-nav-bg-dark);
      --color-nav-border: var(--color-nav-border-dark);
      --color-hover-surface: var(--color-hover-surface-dark);
    }
  </style>
</head>

<body class="bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 font-sans antialiased transition-colors duration-200">

  <!-- Nav -->
  <header class="sticky top-0 z-10 bg-[var(--color-nav-bg)] backdrop-blur border-b border-[var(--color-nav-border)] shadow-[0_1px_0_0_var(--color-nav-border)]">
    <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between"> <!--max-w-5xl indicate the max size of the page-->
      <a href="/" aria-label={`${config.author} home`} class="flex items-center rounded-md transition-opacity hover:opacity-90">
        <img src="/logo_light.svg" alt="" width="28" height="28" class="h-7 w-7 block dark:hidden" />
        <img src="/logo_dark.svg" alt="" width="28" height="28" class="h-7 w-7 hidden dark:block" />
        <span class="sr-only">{config.author}</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="/#projects" class="text-sm text-[var(--color-text-muted)] hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Projects</a>
        <a href="/blog" class="text-sm text-[var(--color-text-muted)] hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Blog</a>
        <a href={config.social.github} target="_blank" rel="noopener" class="text-sm text-[var(--color-text-muted)] hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">
          GitHub ↗
        </a>
        <!-- Dark mode toggle -->
        <button id="theme-toggle" class="w-8 h-8 flex items-center justify-center rounded-md text-[var(--color-text-muted)] hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-[var(--color-hover-surface)] transition-colors" aria-label="Toggle dark mode">
          <svg id="icon-sun" class="hidden dark:block w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
          </svg>
          <svg id="icon-moon" class="block dark:hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>
      </div>
    </nav>
  </header>

  <!-- Main content -->
  <main class="max-w-5xl mx-auto px-6 py-16">
    <slot /><!-- slot is where the content of the page will be injected. When we use this layout in a page, whatever we put inside the <Layout> component will be rendered here -->
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-line)] mt-16">
    <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <span class="font-mono text-xs text-[var(--color-text-subtle)]">{config.domain}</span>
      <div class="flex items-center gap-5">
        <a href={config.social.github} target="_blank" rel="noopener" class="text-xs text-[var(--color-text-subtle)] hover:text-zinc-800 dark:hover:text-zinc-200 transition-colors">GitHub</a>
        <a href={config.social.linkedin} target="_blank" rel="noopener" class="text-xs text-[var(--color-text-subtle)] hover:text-zinc-800 dark:hover:text-zinc-200 transition-colors">LinkedIn</a>
        <a href="/rss.xml" class="text-xs text-[var(--color-text-subtle)] hover:text-zinc-800 dark:hover:text-zinc-200 transition-colors">RSS</a>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  </script>

</body>
</html>
